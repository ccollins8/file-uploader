<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

<%- include("partials/header.ejs") %>

<main>
    <% if (locals.user) { %>
        <h3>You are logged in, <span><%- user.username %></span>!</h3>
        <p>You can now access your files and folders.</p>
    <% } else { %>
        <h3>Welcome to the File Uploader</h3>
        <p>Please log in or sign up to get started.</p>
    <% } %>
    
    <% if (locals.user) { %>
        <%- include("partials/upload-file-form.ejs") %>
        <%- include("partials/create-folder-form.ejs") %>

        <div>
            <% folders.forEach(folder => { %>
                <div>
                    <a href="/folders/<%= folder.id %>">
                        <span>📁</span>
                        <span><%= folder.name %></span>
                    </a>
                    <form action="/folders/<%= folder.id %>/update" method="POST" style="display: inline;">
                <input type="text" name="newName" placeholder="New name" required>
                <button type="submit">Rename</button>
            </form>

            <form action="/folders/<%= folder.id %>/delete" method="POST" style="display: inline;">
                <button type="submit" onclick="return confirm('Delete this folder?')">Delete</button>
            </form>
                </div>
            <% }); %>
        </div>

        <% files.forEach(file => { %>
            <p><%- file.originalName %></p>
        <% }); %>
    <% } %>
</main>

</body>
</html>