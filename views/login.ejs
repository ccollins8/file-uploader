<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>User Login</title>
<!-- Load Tailwind CSS -->
<script src="https://cdn.tailwindcss.com"></script>
<style>
/* Custom font import for a modern look */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap');

    body {
        font-family: 'Inter', sans-serif;
        background-color: #f0f4f8; /* Light gray background */
    }
</style>


</head>
<body class="min-h-screen">

<!-- INCORPORATED HEADER PARTIAL HERE -->
<%- include("partials/header.ejs") %>

<!-- Main Content Wrapper: Centers the login card below the header -->
<!-- We use min-h-[calc(100vh-XXpx)] to ensure content fills the screen 
     even with a header of unknown height, providing vertical centering. -->
<main class="flex items-center justify-center p-4">

    <!-- Login Card Container -->
    <div class="w-full max-w-md bg-white shadow-xl rounded-xl p-8 sm:p-10 border border-gray-100 my-10">
        
        <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-6">
            Sign In to File Uploader
        </h2>
        
        <form action="/login" method="POST" class="space-y-6">
            
            <!-- Username Field -->
            <div>
                <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                <input 
                    type="text" 
                    name="username" 
                    id="username" 
                    autocomplete="username" 
                    required 
                    placeholder="Enter your username"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-150 ease-in-out"
                >
            </div>

            <!-- Password Field -->
            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input 
                    type="password" 
                    name="password" 
                    id="password" 
                    autocomplete="current-password" 
                    required 
                    placeholder="Enter your password"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-150 ease-in-out"
                >
            </div>

            <!-- Submit Button -->
            <div>
                <button 
                    type="submit" 
                    class="w-full flex justify-center py-2 px-4 border border-transparent rounded-lg shadow-lg text-lg font-semibold text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out transform hover:scale-[1.01]"
                >
                    Log In
                </button>
            </div>
        </form>

        <!-- Footer Link -->
        <div class="mt-6 text-center">
            <p class="text-sm text-gray-600">
                Don't have an account? 
                <a href="/sign-up" class="font-medium text-indigo-600 hover:text-indigo-500 transition duration-150 ease-in-out">
                    Sign Up here
                </a>
            </p>
        </div>
    </div>
</main>


</body>
</html>