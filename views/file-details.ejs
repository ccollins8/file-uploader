<<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= file.originalName %> - Details</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <%- include("partials/header.ejs") %>

    <main class="max-w-2xl mx-auto mt-10 bg-white p-8 rounded-lg shadow">
        <!-- <a href="javascript:history.back()" class="text-sm text-indigo-600 mb-4 inline-block">← Back</a> -->
         <% const backURL = file.folderId ? '/folders/' + file.folderId : '/folders' %>
         <a href="<%= backURL %>" class="text-sm text-indigo-600 mb-4 inline-block">
            ← Back to <%= file.folderId ? 'Folder' : 'My Files' %>
        </a>
        
        <h1 class="text-3xl font-bold mb-6 text-gray-800"><%= file.originalName %></h1>

        <div class="space-y-4">
            <div class="flex justify-between border-b pb-2">
                <span class="text-gray-500">Size:</span>
                <span class="font-mono"><%= (file.size / 1024).toFixed(2) %> KB</span>
            </div>
            <div class="flex justify-between border-b pb-2">
                <span class="text-gray-500">Uploaded:</span>
                <span><%= file.uploadDate.toDateString() %></span>
            </div>
            <div class="flex justify-between border-b pb-2">
                <span class="text-gray-500">MIME Type:</span>
                <span><%= file.mimeType %></span>
            </div>
            <div class="flex justify-between border-b pb-2">
                <span class="text-gray-500">Stored At:</span>
                <span class="text-xs text-gray-400"><%= file.filePath %></span>
            </div>
        </div>

        <div class="mt-8 flex gap-4">
            <a href="/download/<%= file.id %>" class="bg-indigo-600 text-white px-4 py-2 rounded">Download File</a>
        </div>
    </main>
</body>
</html>