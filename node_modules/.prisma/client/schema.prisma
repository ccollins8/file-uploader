generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  password String
  files    File[]
  folders  Folder[]
}

// model File {
//   id    Int     @id @default(autoincrement())
//   user_id Int
//   folder_id Int

//   user    User     @relation(fields: [user_id], references: [id])
//   folder    Folder     @relation(fields: [folder_id], references: [id])
// }

model File {
  id Int @id @default(autoincrement())

  // Metadata fields saved by Multer
  fileName     String
  originalName String
  mimeType     String?
  filePath     String
  size         Int
  uploadDate   DateTime @default(now())

  // CRITICAL: DIRECT LINK TO OWNER
  userId Int
  user   User @relation(fields: [userId], references: [id])

  // OPTIONAL: LINK TO LOCATION
  folderId Int? // ⬅️ OPTIONAL: Null means the file is in the root directory
  folder   Folder? @relation(fields: [folderId], references: [id])
}

// model Folder {
//   id    Int     @id @default(autoincrement())
//   name String
//   user_id Int
//   subfolders Folder[]
//   files File[]

//   user    User     @relation(fields: [user_id], references: [id])

//   parentId   Int?
//   parent     Folder?  @relation("FolderStructure", fields: [parentId], references: [id])
//   children   Folder[] @relation("FolderStructure")

// }

model Folder {
  id         Int      @id @default(autoincrement())
  name       String
  uploadDate DateTime @default(now())

  // DIRECT LINK TO OWNER
  userId Int
  user   User @relation(fields: [userId], references: [id])

  // Link to Files contained within
  files File[]

  // For nested folders (self-relation for future steps)
  parentId Int?
  parent   Folder?  @relation("FolderStructure", fields: [parentId], references: [id])
  children Folder[] @relation("FolderStructure")
}
